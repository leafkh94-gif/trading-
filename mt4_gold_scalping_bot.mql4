//+------------------------------------------------------------------+
//|                        Gold Scalping Bot MQL4                     |
//|                    Professional XAUUSD Trading EA                 |
//+------------------------------------------------------------------+
//| 
//| STRATEGY OVERVIEW:
//| Aggressive scalping bot for XAUUSD with advanced risk management
//| 
//| FEATURES:
//| - Real-time technical indicator analysis (RSI, MACD, MA)
//| - Dynamic position sizing based on volatility
//| - Support/resistance breakout detection
//| - Advanced risk management with trailing stops
//| - Performance monitoring and trade tracking
//|
//+------------------------------------------------------------------+

#property copyright "Trading Bot Platform"
#property link      "https://github.com/trading-bot"
#property version   "1.0"
#property strict

// ============================================================
// EXTERNAL PARAMETERS
// ============================================================

extern int    MagicNumber           = 12345;        // Unique EA identifier
extern double RiskPercentage        = 1.5;          // Risk per trade (%)
extern double MaxDrawdown           = 5.0;          // Max daily loss (%)
extern int    MaxOpenPositions      = 3;            // Maximum concurrent trades
extern string Strategy              = "scalping";   // Strategy type

// Technical Indicators Settings
extern int    RSI_Period            = 14;           // RSI period
extern int    RSI_Oversold          = 30;           // RSI oversold level
extern int    RSI_Overbought        = 70;           // RSI overbought level
extern int    MA_Fast               = 9;            // Fast MA period
extern int    MA_Slow               = 21;           // Slow MA period
extern int    MACD_Fast             = 12;           // MACD fast period
extern int    MACD_Slow             = 26;           // MACD slow period

// Risk Management Settings
extern double TakeProfitRatio       = 2.5;          // Risk-reward ratio
extern double TrailingStop          = 15;           // Trailing stop (pips)
extern bool   UseTrailingStop       = true;         // Enable trailing stop

// Time Filters
extern int    StartHour             = 0;            // Trading start hour (UTC)
extern int    EndHour               = 23;           // Trading end hour (UTC)
extern bool   UseTimeFilter         = false;        // Enable time filtering

// ============================================================
// GLOBAL VARIABLES
// ============================================================

double DailyLoss = 0.0;             // Accumulated daily loss
int    TradesOpen = 0;              // Number of open trades
int    TradesDaily = 0;             // Trades opened today
double AccountStartBalance = 0.0;   // Starting balance for session

// ============================================================
// INITIALIZATION
// ============================================================

int OnInit()
{
    Print("=== Gold Scalping Bot MQL4 Started ===");
    Print("Magic Number: ", MagicNumber);
    Print("Risk Per Trade: ", RiskPercentage, "%");
    Print("Max Open Positions: ", MaxOpenPositions);
    
    AccountStartBalance = AccountBalance();
    
    return(INIT_SUCCEEDED);
}

// ============================================================
// MAIN TRADING LOGIC
// ============================================================

void OnTick()
{
    // Check if new day - reset counters
    if(Hour() == 0 && Minute() < 2)
    {
        ResetDailyCounters();
    }
    
    // Update daily loss
    UpdateDailyLoss();
    
    // Check if we should trade
    if(!IsTradingTime())
    {
        return;
    }
    
    // Analyze market
    double RSI = CalculateRSI();
    double MACD = CalculateMACD();
    double SignalLine = CalculateMACDSignal();
    double MA_Fast = iMA(Symbol(), 0, MA_Fast, 0, MODE_SMA, PRICE_CLOSE, 0);
    double MA_Slow = iMA(Symbol(), 0, MA_Slow, 0, MODE_SMA, PRICE_CLOSE, 0);
    double ATR = iATR(Symbol(), 0, 14, 0);
    
    // Generate trading signal
    int Signal = GenerateSignal(RSI, MACD, SignalLine, MA_Fast, MA_Slow);
    
    // Execute trade if signal is valid
    if(Signal != 0)
    {
        double Entry = Ask;
        double StopLoss = CalculateStopLoss(Signal, ATR, Entry);
        double TakeProfit = CalculateTakeProfit(Signal, Entry, StopLoss);
        double LotSize = CalculateLotSize(Entry, StopLoss);
        
        // Validate trade
        if(ValidateTrade(Entry, StopLoss, TakeProfit, LotSize))
        {
            ExecuteTrade(Signal, Entry, StopLoss, TakeProfit, LotSize);
        }
    }
    
    // Update open trades
    UpdateOpenTrades();
}

// ============================================================
// SIGNAL GENERATION
// ============================================================

int GenerateSignal(double RSI, double MACD, double SignalLine, double MA_Fast, double MA_Slow)
{
    // BUY Signal: RSI oversold + Uptrend + MACD positive
    if(RSI < RSI_Oversold && MA_Fast > MA_Slow && MACD > SignalLine)
    {
        return(1);  // BUY
    }
    
    // SELL Signal: RSI overbought + Downtrend + MACD negative
    if(RSI > RSI_Overbought && MA_Fast < MA_Slow && MACD < SignalLine)
    {
        return(-1);  // SELL
    }
    
    return(0);  // NO SIGNAL
}

// ============================================================
// TECHNICAL INDICATORS
// ============================================================

double CalculateRSI()
{
    return iRSI(Symbol(), 0, RSI_Period, PRICE_CLOSE, 0);
}

double CalculateMACD()
{
    return iMACD(Symbol(), 0, MACD_Fast, MACD_Slow, 9, PRICE_CLOSE, MODE_MAIN, 0);
}

double CalculateMACDSignal()
{
    return iMACD(Symbol(), 0, MACD_Fast, MACD_Slow, 9, PRICE_CLOSE, MODE_SIGNAL, 0);
}

// ============================================================
// RISK MANAGEMENT
// ============================================================

double CalculateStopLoss(int Signal, double ATR, double Entry)
{
    if(Signal == 1)  // BUY
    {
        return Entry - (ATR * 1.2);
    }
    else if(Signal == -1)  // SELL
    {
        return Entry + (ATR * 1.2);
    }
    
    return 0;
}

double CalculateTakeProfit(int Signal, double Entry, double StopLoss)
{
    double RiskDistance = MathAbs(Entry - StopLoss);
    double RewardDistance = RiskDistance * TakeProfitRatio;
    
    if(Signal == 1)  // BUY
    {
        return Entry + RewardDistance;
    }
    else  // SELL
    {
        return Entry - RewardDistance;
    }
}

double CalculateLotSize(double Entry, double StopLoss)
{
    double RiskAmount = AccountBalance() * (RiskPercentage / 100.0);
    double PipsRisk = MathAbs(Entry - StopLoss);
    
    if(PipsRisk == 0) return 0.01;
    
    double LotSize = RiskAmount / PipsRisk;
    double MaxLotSize = (AccountBalance() * 5.0 / 100.0) / Entry;  // Max 5% position
    
    LotSize = MathMin(LotSize, MaxLotSize);
    LotSize = MathMax(LotSize, 0.01);  // Minimum lot size
    
    return NormalizeDouble(LotSize, 2);
}

bool ValidateTrade(double Entry, double StopLoss, double TakeProfit, double LotSize)
{
    // Check daily loss limit
    if(DailyLoss >= AccountBalance() * (MaxDrawdown / 100.0))
    {
        Print("Daily loss limit exceeded: ", DailyLoss);
        return false;
    }
    
    // Check max open positions
    if(CountOpenPositions() >= MaxOpenPositions)
    {
        Print("Maximum open positions reached: ", MaxOpenPositions);
        return false;
    }
    
    // Check if lot size is valid
    if(LotSize < 0.01)
    {
        Print("Lot size too small: ", LotSize);
        return false;
    }
    
    // Check margin
    if(GetFreeMargingPercent() < 50)
    {
        Print("Insufficient margin");
        return false;
    }
    
    return true;
}

// ============================================================
// TRADE EXECUTION
// ============================================================

void ExecuteTrade(int Signal, double Entry, double StopLoss, double TakeProfit, double LotSize)
{
    string Comment = "Gold Bot - " + (Signal == 1 ? "BUY" : "SELL") + " - " + TimeToStr(TimeCurrent());
    
    if(Signal == 1)  // BUY
    {
        int Ticket = OrderSend(
            Symbol(),
            OP_BUY,
            LotSize,
            Ask,
            3,  // Slippage
            StopLoss,
            TakeProfit,
            Comment,
            MagicNumber,
            0,
            Green
        );
        
        if(Ticket > 0)
        {
            Print("BUY order opened: ", Ticket);
            Print("Lot Size: ", LotSize, " SL: ", StopLoss, " TP: ", TakeProfit);
            TradesDaily++;
        }
        else
        {
            Print("Failed to open BUY order. Error: ", GetLastError());
        }
    }
    else if(Signal == -1)  // SELL
    {
        int Ticket = OrderSend(
            Symbol(),
            OP_SELL,
            LotSize,
            Bid,
            3,  // Slippage
            StopLoss,
            TakeProfit,
            Comment,
            MagicNumber,
            0,
            Red
        );
        
        if(Ticket > 0)
        {
            Print("SELL order opened: ", Ticket);
            Print("Lot Size: ", LotSize, " SL: ", StopLoss, " TP: ", TakeProfit);
            TradesDaily++;
        }
        else
        {
            Print("Failed to open SELL order. Error: ", GetLastError());
        }
    }
}

// ============================================================
// POSITION MANAGEMENT
// ============================================================

void UpdateOpenTrades()
{
    for(int i = OrdersTotal() - 1; i >= 0; i--)
    {
        if(!OrderSelect(i, SELECT_BY_POS, MODE_TRADES))
            continue;
        
        if(OrderMagicNumber() != MagicNumber)
            continue;
        
        if(OrderSymbol() != Symbol())
            continue;
        
        // Apply trailing stop if enabled
        if(UseTrailingStop && OrderType() == OP_BUY)
        {
            double TrailingStopPrice = Ask - TrailingStop * Point;
            if(TrailingStopPrice > OrderStopLoss())
            {
                OrderModify(OrderTicket(), OrderOpenPrice(), TrailingStopPrice, OrderTakeProfit(), 0, Green);
            }
        }
        else if(UseTrailingStop && OrderType() == OP_SELL)
        {
            double TrailingStopPrice = Bid + TrailingStop * Point;
            if(TrailingStopPrice < OrderStopLoss())
            {
                OrderModify(OrderTicket(), OrderOpenPrice(), TrailingStopPrice, OrderTakeProfit(), 0, Red);
            }
        }
    }
}

int CountOpenPositions()
{
    int Count = 0;
    for(int i = OrdersTotal() - 1; i >= 0; i--)
    {
        if(!OrderSelect(i, SELECT_BY_POS, MODE_TRADES))
            continue;
        
        if(OrderMagicNumber() == MagicNumber && OrderSymbol() == Symbol())
        {
            Count++;
        }
    }
    return Count;
}

// ============================================================
// UTILITY FUNCTIONS
// ============================================================

bool IsTradingTime()
{
    if(!UseTimeFilter)
        return true;
    
    int CurrentHour = Hour();
    return (CurrentHour >= StartHour && CurrentHour <= EndHour);
}

void UpdateDailyLoss()
{
    // Calculate unrealized and realized losses
    double CurrentBalance = AccountBalance();
    double SessionProfit = AccountBalance() - AccountStartBalance;
    
    if(SessionProfit < 0)
    {
        DailyLoss = MathAbs(SessionProfit);
    }
}

double GetFreeMargingPercent()
{
    if(AccountMargin() == 0)
        return 100.0;
    
    return (AccountFreeMargin() / AccountMargin()) * 100.0;
}

void ResetDailyCounters()
{
    DailyLoss = 0.0;
    TradesDaily = 0;
    AccountStartBalance = AccountBalance();
    Print("Daily counters reset at ", TimeToStr(TimeCurrent()));
}

void OnDeinit(const int reason)
{
    Print("=== Gold Scalping Bot MQL4 Stopped ===");
    Print("Total Trades Today: ", TradesDaily);
    Print("Final Balance: ", AccountBalance());
}

// ============================================================
// COMMENT
// ============================================================

